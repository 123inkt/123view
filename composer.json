{
    "name": "digitalrevolution/review",
    "description": "A code review and commit notification symfony application",
    "keywords": ["git", "commit", "summary", "bundle", "filter", "mail", "notification"],
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "process-timeout": 0,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "DR\\Review\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DR\\Review\\Tests\\Functional\\": "tests/Functional",
            "DR\\Review\\Tests\\Integration\\": "tests/Integration",
            "DR\\Review\\Tests\\Unit\\": "tests/Unit",
            "DR\\Review\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "ext-mbstring": "*",
        "ext-zlib": "*",
        "api-platform/core": "^4.2",
        "czproject/git-php": "^4.5",
        "digitalrevolution/jbdiff": "^1.2",
        "digitalrevolution/symfony-console-validation": "^2.0",
        "digitalrevolution/symfony-request-validation": "^3.0",
        "digitalrevolution/symfony-trace-bundle": "^1.0",
        "digitalrevolution/utils": "^1.28",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.1",
        "fdekker/commonmark-ext-emoji": "^1.1",
        "fdekker/log-viewer-bundle": "^2.7",
        "league/commonmark": "^2.4",
        "league/oauth2-client": "^2.9",
        "league/uri": "^7.8",
        "liip/monitor-bundle": "dev-feature/php85-symfony8#11d7d3eb307d61c683980d7a5c233586a6c277d7",
        "nesbot/carbon": "^3.11",
        "nette/utils": "^4.0",
        "parsica-php/parsica": "^0.8.3",
        "phpdocumentor/reflection-docblock": "^5.6",
        "scienta/doctrine-json-functions": "^6.3",
        "spatie/commonmark-highlighter": "^3.0",
        "symfony/ai-agent": "^0.6",
        "symfony/ai-anthropic-platform": "^0.6",
        "symfony/ai-bundle": "^0.6",
        "symfony/amqp-messenger": "^8.0",
        "symfony/asset": "^8.0",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/doctrine-messenger": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/expression-language": "^8.0",
        "symfony/filesystem": "^8.0",
        "symfony/flex": "^2.10",
        "symfony/form": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/mailer": "^8.0",
        "symfony/mercure-bundle": "^0.4.0",
        "symfony/messenger": "^8.0",
        "symfony/monolog-bundle": "^4.0",
        "symfony/process": "^8.0",
        "symfony/property-access": "^8.0",
        "symfony/property-info": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/stimulus-bundle": "^2.22",
        "symfony/string": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/uid": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/webhook": "^8.0",
        "symfony/webpack-encore-bundle": "^2.3",
        "symfony/yaml": "^8.0",
        "thenetworg/oauth2-azure": "^2.2",
        "tijsverkoyen/css-to-inline-styles": "^2.4",
        "twig/extra-bundle": "^3.23",
        "twig/intl-extra": "^3.23",
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "digitalrevolution/accessorpair-constraint": "^2.7",
        "digitalrevolution/phpunit-extensions": "^1.13",
        "digitalrevolution/phpunit-file-coverage-inspection": "^3.1",
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "liip/test-fixtures-bundle": "^3.8",
        "mikey179/vfsstream": "^1.6",
        "phpmd/phpmd": "3.x-dev",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1.40",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^13.0.0",
        "roave/security-advisories": "dev-latest",
        "slevomat/coding-standard": "^8.28",
        "squizlabs/php_codesniffer": "^4.0",
        "symfony/browser-kit": "^8.0",
        "symfony/debug-bundle": "^8.0",
        "symfony/error-handler": "^8.0",
        "symfony/maker-bundle": "^1.66",
        "symfony/phpunit-bridge": "^8.0",
        "symfony/stopwatch": "^8.0",
        "symfony/var-dumper": "^8.0",
        "symfony/web-profiler-bundle": "^8.0",
        "yep/reflection": "^2.1"
    },
    "replace": {
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-intl-icu": "*",
        "symfony/polyfill-intl-grapheme": "*",
        "symfony/polyfill-intl-messageformatter": "*",
        "symfony/polyfill-intl-normalizer": "*",
        "symfony/polyfill-intl-idn": "*",
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "repositories": [
        {"type": "vcs", "url": "https://github.com/HecFranco/LiipMonitorBundle.git"}
    ],
    "scripts": {
        "auto-scripts": {
            "cache:clear --no-warmup": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"],
        "baseline:phpstan": "phpstan --generate-baseline",
        "baseline:phpmd": "@php vendor/bin/phpmd analyze src tests --no-progress --ruleset phpmd.xml --generate-baseline",
        "check": ["@check:phpstan", "@check:phpmd", "@check:phpcs"],
        "check:phpstan": "@php -dxdebug.mode=off vendor/bin/phpstan analyse",
        "check:phpmd": "@php vendor/bin/phpmd analyze src tests --no-progress --format text --ruleset phpmd.xml --cache --cache-file var/.phpmd.result-cache.php",
        "check:phpcs": "@php vendor/bin/phpcs src tests",
        "fix": "@fix:phpcbf",
        "fix:phpcbf": "phpcbf src tests",
        "test": "phpunit",
        "test:functional": "phpunit --testsuite functional",
        "test:integration": "phpunit --testsuite integration",
        "test:unit": "phpunit --testsuite unit",
        "test:coverage": [
            "phpunit --testsuite unit --coverage-clover coverage.xml",
            "phpfci inspect coverage.xml --reportText --exit-code-on-failure"
        ],
        "cache:destroy": [
            "@php bin/console cache:clear --env=prod --no-debug",
            "@php bin/console cache:clear --env=dev  --no-debug",
            "@php bin/console cache:clear --env=test --no-debug"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true,
            "require": "8.0.*"
        }
    }
}
